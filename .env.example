PORT=3000

# Data provider: mock | oura
PROVIDER=mock

# Oura — option A: personal access token (your own ring)
# https://cloud.ouraring.com/personal-access-tokens
OURA_PERSONAL_ACCESS_TOKEN=

# Oura — option B: OAuth app (other users connect their rings)
# https://cloud.ouraring.com/oauth/applications
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:3000/oauth/oura/callback

# Future integrations
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3000/oauth/whoop/callback

WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
